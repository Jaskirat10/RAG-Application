GOOGLE_API_KEY=your_google_api_key_here

# LLM model
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ── Embedding provider ──────────────────────────────────────────────────────
# "google" → uses gemini-embedding-001 via Google API (requires GOOGLE_API_KEY)
# "local"  → uses sentence-transformers model on your machine (no API needed)
EMBEDDING_PROVIDER=google

# Local model to use when EMBEDDING_PROVIDER=local
# Options: BAAI/bge-small-en-v1.5 (384d), BAAI/bge-large-en-v1.5 (1024d), all-MiniLM-L6-v2 (384d)
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Must match your chosen model's output dimensions:
#   gemini-embedding-001    → 3072
#   bge-small-en-v1.5       → 384
#   bge-large-en-v1.5       → 1024
#   all-MiniLM-L6-v2        → 384
# IMPORTANT: if you change provider/model, delete chroma_db/ and re-ingest
EMBEDDING_DIM=3072
